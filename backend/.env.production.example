# Production env var template — fill these in Railway's UI per service.
# DO NOT commit a real .env.production file.

# --- Runtime ---
ENVIRONMENT=production

# --- Data layer ---
# Railway's PostgreSQL plugin exposes DATABASE_URL automatically;
# we only need to add the +asyncpg dialect prefix in our Start Command, e.g.:
#   DATABASE_URL=postgresql+asyncpg://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
# Or simpler: set DATABASE_URL via Railway's variable references UI.
DATABASE_URL=

# Railway's Redis plugin exposes REDIS_URL automatically.
REDIS_URL=

# --- External APIs ---
FRED_API_KEY=
SEC_USER_AGENT=EventSense your-email@example.com

# --- LLM (Milestone 5+) ---
OPENAI_API_KEY=
# Optional — leave blank to keep router on OpenAI only
ANTHROPIC_API_KEY=
LLM_DAILY_COST_CAP_USD=5.0
LLM_DEFAULT_MODEL=gpt-5-mini
LLM_PREMIUM_MODEL=gpt-5

# --- Watchlist ---
DEFAULT_TICKERS=NVDA,TSLA,AAPL,MSFT,GOOGL,META,AMZN,AVGO,BRK-B,LLY,SPY,QQQ

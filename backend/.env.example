# Copy to .env and fill in real values. Never commit .env.

# Runtime
ENVIRONMENT=development

# Database (asyncpg URL — note the postgresql+asyncpg:// scheme, not plain postgresql://)
DATABASE_URL=postgresql+asyncpg://eventsense:eventsense@localhost:5432/eventsense

# Redis (broker + cache; not exercised until Milestone 2)
REDIS_URL=redis://localhost:6379/0

# FRED API — register at https://fred.stlouisfed.org/docs/api/api_key.html (free, ~1 min)
FRED_API_KEY=

# SEC EDGAR — no API key needed, but a custom User-Agent identifying you is mandatory.
# Format: "Company Name email@example.com" (must contain an email)
SEC_USER_AGENT=EventSense your-email@example.com

# Copy to .env and fill in real values. Never commit .env.

# Runtime
ENVIRONMENT=development

# Database (asyncpg URL — note the postgresql+asyncpg:// scheme, not plain postgresql://)
DATABASE_URL=postgresql+asyncpg://eventsense:eventsense@localhost:5432/eventsense

# Redis (broker + cache; not exercised until Milestone 2)
REDIS_URL=redis://localhost:6379/0

# FRED API — register at https://fred.stlouisfed.org/docs/api/api_key.html (free, ~1 min)
FRED_API_KEY=

# SEC EDGAR — no API key needed, but a custom User-Agent identifying you is mandatory.
# Format: "Company Name email@example.com" (must contain an email)
SEC_USER_AGENT=EventSense your-email@example.com

# LLM analysis (Milestone 5+) — at least one of OPENAI_API_KEY or ANTHROPIC_API_KEY
# must be set, depending on which model llm_default_model / llm_premium_model resolve to.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Daily spend cap in USD. When exceeded, premium calls downgrade to the default model.
LLM_DAILY_COST_CAP_USD=5.0
# Default model used for most events; premium for high-stakes (FOMC, CPI).
LLM_DEFAULT_MODEL=gpt-5-mini
LLM_PREMIUM_MODEL=gpt-5

# Fed speeches/testimony ingestion: which Board speakers to ingest.
#   all (default) — Chair + Vice Chair + Governors
#   principals    — Chair + Vice Chair only
#   chair         — Chair only
FED_SPEAKER_SCOPE=all

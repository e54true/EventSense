{
  "uid": "eventsense-overview",
  "title": "EventSense — Overview",
  "tags": ["eventsense", "milestone-11"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "HTTP (RED metrics)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Request rate",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "eventsense-prom" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_requests_total[5m]))", "datasource": { "type": "prometheus", "uid": "eventsense-prom" } }
      ]
    },
    {
      "type": "stat",
      "title": "Error ratio (5xx)",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "eventsense-prom" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "decimals": 2, "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1e-9)", "datasource": { "type": "prometheus", "uid": "eventsense-prom" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (s)",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "eventsense-prom" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "p50", "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "datasource": { "type": "prometheus", "uid": "eventsense-prom" } },
        { "refId": "B", "legendFormat": "p95", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "datasource": { "type": "prometheus", "uid": "eventsense-prom" } },
        { "refId": "C", "legendFormat": "p99", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "datasource": { "type": "prometheus", "uid": "eventsense-prom" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request rate by handler",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "eventsense-prom" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "{{handler}} ({{status}})", "expr": "sum by (handler, status) (rate(http_requests_total[5m]))", "datasource": { "type": "prometheus", "uid": "eventsense-prom" } }
      ]
    },
    {
      "type": "row",
      "title": "Celery (background pipeline)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 6,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Task throughput by name (succeeded)",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "eventsense-prom" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "{{name}}", "expr": "sum by (name) (rate(celery_task_succeeded_total[5m]))", "datasource": { "type": "prometheus", "uid": "eventsense-prom" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Task failures by name",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "eventsense-prom" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 }, "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "{{name}}", "expr": "sum by (name) (rate(celery_task_failed_total[5m]))", "datasource": { "type": "prometheus", "uid": "eventsense-prom" } }
      ]
    },
    {
      "type": "row",
      "title": "Domain (business state)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 9,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Event pipeline funnel (by status)",
      "id": 10,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "eventsense-prom" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "{{status}}", "expr": "sum by (status) (eventsense_events)", "datasource": { "type": "prometheus", "uid": "eventsense-prom" } }
      ]
    },
    {
      "type": "bargauge",
      "title": "Directional accuracy by window",
      "id": 11,
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "eventsense-prom" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.6 }] } }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "legendFormat": "{{window}}", "expr": "eventsense_directional_accuracy", "datasource": { "type": "prometheus", "uid": "eventsense-prom" } }
      ]
    },
    {
      "type": "stat",
      "title": "LLM spend today vs cap (USD)",
      "id": 12,
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "eventsense-prom" },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 3, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 5 }] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "legendFormat": "spent", "expr": "eventsense_llm_cost_today_usd", "datasource": { "type": "prometheus", "uid": "eventsense-prom" } },
        { "refId": "B", "legendFormat": "cap", "expr": "eventsense_llm_cost_cap_usd", "datasource": { "type": "prometheus", "uid": "eventsense-prom" } }
      ]
    }
  ]
}
